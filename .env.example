APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# En producción debe ser false para no exponer datos sensibles en errores
APP_DEBUG=true
APP_URL=http://localhost

# Registro de clínicas / provisionamiento interno (obligatorio en producción)
CLINIC_REGISTRATION_SECRET=
INTERNAL_CONSULTORIO_SETUP_SECRET=

# URL pública del SPA (enlaces en correos: consentimiento paciente, etc.)
FRONTEND_URL=http://localhost:5173

# Versiones legales y URLs de documentos (LFPDPPP / términos)
LEGAL_VERSION_AVISO=2026-04-01
LEGAL_VERSION_TERMINOS=2026-04-01
LEGAL_URL_AVISO_PRIVACIDAD=https://lynkamed.mx/aviso-privacidad
LEGAL_URL_TERMINOS=https://lynkamed.mx/terminos
LEGAL_CONSENT_LINK_DAYS=14

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=30

# AI Usage Limits (requests per user per day)
# Para desarrollo: AI_CHAT_LIMIT=99999
# Para producción: AI_CHAT_LIMIT=50
AI_CHAT_LIMIT=50
AI_AUTOCOMPLETE_LIMIT=30
AI_SUMMARIZE_LIMIT=20

# ==========================================
# STRIPE - Pagos y Suscripciones
# ==========================================
# Crear cuenta: https://stripe.com
# Obtener keys: https://dashboard.stripe.com/test/apikeys
# Configurar webhook: https://dashboard.stripe.com/test/webhooks
#   - Endpoint: https://tu-dominio.com/api/registro/webhook/stripe
#   - Eventos: checkout.session.completed, customer.subscription.deleted
STRIPE_KEY=pk_test_51...
STRIPE_SECRET=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio WhatsApp - Recordatorios de Citas
# Obtener credenciales: https://console.twilio.com/
# Configurar webhook: https://console.twilio.com/us1/develop/sms/settings/whatsapp-sandbox
#   - When a message comes in: https://tu-dominio.com/api/whatsapp/webhook (POST)
#   - Status callback URL: https://tu-dominio.com/api/whatsapp/status (POST)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_ENABLED=false

# Email del equipo comercial (notificaciones de contacto)
MAIL_COMMERCIAL_TEAM=ventas@lynkamed.mx
